<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.skylark.permission.authorization.mapper.OperationLogMapper">

    <resultMap id="BaseResultMap" type="cn.skylark.permission.authorization.entity.SysOperationLog">
        <id column="id" property="id" jdbcType="BIGINT"/>
        <result column="tenant_id" property="tenantId" jdbcType="BIGINT"/>
        <result column="user_id" property="userId" jdbcType="BIGINT"/>
        <result column="username" property="username" jdbcType="VARCHAR"/>
        <result column="http_method" property="httpMethod" jdbcType="VARCHAR"/>
        <result column="request_uri" property="requestUri" jdbcType="VARCHAR"/>
        <result column="http_status" property="httpStatus" jdbcType="INTEGER"/>
        <result column="duration_ms" property="durationMs" jdbcType="BIGINT"/>
        <result column="client_ip" property="clientIp" jdbcType="VARCHAR"/>
        <result column="created_at" property="createdAt" jdbcType="TIMESTAMP"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, tenant_id, user_id, username, http_method, request_uri, http_status, duration_ms, client_ip, created_at
    </sql>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM sys_operation_log
        WHERE id = #{id}
    </select>

    <insert id="insert" parameterType="cn.skylark.permission.authorization.entity.SysOperationLog" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO sys_operation_log(tenant_id, user_id, username, http_method, request_uri, http_status, duration_ms, client_ip)
        VALUES (#{tenantId}, #{userId}, #{username}, #{httpMethod}, #{requestUri}, #{httpStatus}, #{durationMs}, #{clientIp})
    </insert>

    <select id="selectPage" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM sys_operation_log
        ORDER BY created_at DESC
        LIMIT #{offset}, #{limit}
    </select>

    <select id="selectPageWithCondition" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM sys_operation_log
        <where>
            <if test="username != null and username != ''">
                AND username LIKE CONCAT('%', #{username}, '%')
            </if>
            <if test="httpMethod != null and httpMethod != ''">
                AND http_method = #{httpMethod}
            </if>
            <if test="httpStatus != null">
                AND http_status = #{httpStatus}
            </if>
            <if test="requestUri != null and requestUri != ''">
                AND request_uri LIKE CONCAT('%', #{requestUri}, '%')
            </if>
            <if test="createdTimeStart != null">
                AND created_at &gt;= #{createdTimeStart}
            </if>
            <if test="createdTimeEnd != null">
                AND created_at &lt;= #{createdTimeEnd}
            </if>
            <if test="tenantId != null">
                AND tenant_id = #{tenantId}
            </if>
        </where>
        ORDER BY created_at DESC
        LIMIT #{offset}, #{limit}
    </select>

    <select id="countAll" resultType="long">
        SELECT COUNT(*) FROM sys_operation_log
    </select>

    <select id="countWithCondition" resultType="long">
        SELECT COUNT(*) FROM sys_operation_log
        <where>
            <if test="username != null and username != ''">
                AND username LIKE CONCAT('%', #{username}, '%')
            </if>
            <if test="httpMethod != null and httpMethod != ''">
                AND http_method = #{httpMethod}
            </if>
            <if test="httpStatus != null">
                AND http_status = #{httpStatus}
            </if>
            <if test="requestUri != null and requestUri != ''">
                AND request_uri LIKE CONCAT('%', #{requestUri}, '%')
            </if>
            <if test="createdTimeStart != null">
                AND created_at &gt;= #{createdTimeStart}
            </if>
            <if test="createdTimeEnd != null">
                AND created_at &lt;= #{createdTimeEnd}
            </if>
            <if test="tenantId != null">
                AND tenant_id = #{tenantId}
            </if>
        </where>
    </select>
</mapper>
