<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.skylark.permission.authorization.mapper.PlatformInitStateMapper">

    <resultMap id="BaseResult" type="cn.skylark.permission.authorization.entity.SysPlatformInitState">
        <id column="id" property="id"/>
        <result column="status" property="status"/>
        <result column="finished_at" property="finishedAt"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, status, finished_at, create_time, update_time
    </sql>

    <select id="selectSingleton" resultMap="BaseResult">
        SELECT
        <include refid="Base_Column_List"/>
        FROM sys_platform_init_state
        WHERE id = 1
        LIMIT 1
    </select>

    <insert id="insertSingleton">
        INSERT INTO sys_platform_init_state(id, status, finished_at)
        VALUES (1, #{status}, NULL)
    </insert>

    <update id="updateStatus">
        UPDATE sys_platform_init_state
        SET status = #{status},
            finished_at = #{finishedAt}
        WHERE id = 1
    </update>
</mapper>

