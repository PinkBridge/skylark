<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.skylark.permission.authorization.mapper.PlatformConfigMapper">

    <resultMap id="BaseResult" type="cn.skylark.permission.authorization.entity.SysPlatformConfig">
        <id column="id" property="id"/>
        <result column="config_key" property="configKey"/>
        <result column="config_value" property="configValue"/>
        <result column="value_type" property="valueType"/>
        <result column="description" property="description"/>
        <result column="is_delete" property="isDelete"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, config_key, config_value, value_type, description, is_delete, create_time, update_time
    </sql>

    <select id="selectAll" resultMap="BaseResult">
        SELECT
        <include refid="Base_Column_List"/>
        FROM sys_platform_config
        WHERE is_delete = 0
        ORDER BY config_key
    </select>

    <select id="selectByKey" resultMap="BaseResult">
        SELECT
        <include refid="Base_Column_List"/>
        FROM sys_platform_config
        WHERE config_key = #{configKey}
          AND is_delete = 0
    </select>

    <update id="updateValueByKey">
        UPDATE sys_platform_config
        SET config_value = #{configValue}
        WHERE config_key = #{configKey}
          AND is_delete = 0
    </update>
</mapper>
