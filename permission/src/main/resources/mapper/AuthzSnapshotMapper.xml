<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.skylark.permission.authorization.mapper.AuthzSnapshotMapper">

  <resultMap id="ApiResourceMap" type="cn.skylark.permission.authorization.dto.RbacSnapshotResponse$ApiResource">
    <result column="api_id" property="apiId"/>
    <result column="method" property="method"/>
    <result column="path_pattern" property="pathPattern"/>
    <result column="enabled" property="enabled"/>
  </resultMap>

  <resultMap id="RoleApiBindingMap" type="cn.skylark.permission.authorization.dto.RbacSnapshotResponse$RoleApiBinding">
    <result column="role_name" property="roleName"/>
    <result column="api_id" property="apiId"/>
    <result column="enabled" property="enabled"/>
  </resultMap>

  <select id="selectApisByApp" resultMap="ApiResourceMap">
    SELECT
      a.id AS api_id,
      a.method AS method,
      a.path AS path_pattern,
      1 AS enabled
    FROM sys_api a
    <where>
      <if test="appCode != null and appCode != ''">
        a.app_code = #{appCode}
      </if>
    </where>
    ORDER BY a.id ASC
  </select>

  <select id="selectRoleApiBindingsByApp" resultMap="RoleApiBindingMap">
    SELECT
      r.name AS role_name,
      ra.api_id AS api_id,
      1 AS enabled
    FROM sys_role_api ra
    INNER JOIN sys_role r ON r.id = ra.role_id
    INNER JOIN sys_api a ON a.id = ra.api_id
    <where>
      <if test="appCode != null and appCode != ''">
        a.app_code = #{appCode}
      </if>
      <if test="appCode == null or appCode == ''">
        1 = 1
      </if>
    </where>
    ORDER BY r.name ASC, ra.api_id ASC
  </select>

</mapper>

